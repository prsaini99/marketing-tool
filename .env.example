# Postgres connection strings.
#
# Local dev (Docker):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meta_marketing
#   DIRECT_URL not needed locally (same connection serves both)
#
# Supabase (or any hosted Postgres with pooling):
#   DATABASE_URL → "Transaction pooler" string (port 6543) — used by the app
#   DIRECT_URL   → "Direct connection" string  (port 5432) — used by `prisma migrate`
DATABASE_URL=
DIRECT_URL=

# Encryption key for credentials at rest (AES-256-GCM, 32 bytes base64)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# KEEP STABLE in production. Rotating orphans previously-stored tokens.
ENCRYPTION_KEY=

# Dev convenience — Meta Marketing API token for testing the discovery endpoint
# without going through the UI. In production, users paste their own tokens into
# the app; they live encrypted in the DB, never in env. Leave blank if unused.
META_TEST_TOKEN=

# Master credentials — single-user gate for the platform. The /login page
# validates email+password against these. Change to rotate access.
MASTER_EMAIL=
MASTER_PASSWORD=

# Session signing key — used to HMAC the session cookie so it can't be
# forged. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# KEEP STABLE in production. Rotating logs everyone out.
SESSION_SECRET=

# ─── RAG + LLM ──────────────────────────────────────────────────────────
# Required for any AI feature (copy gen, audits, narrative reports, "ask
# my data", multi-account triage). One vendor for the whole AI stack —
# OpenAI handles both embeddings (text-embedding-3-small, 1536-d, RAG
# retrieval) and chat completions (GPT-4o default, used by every LLM call
# via src/lib/llm/chat.ts). Stays server-side — same discipline as Meta
# tokens. Get a key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=
