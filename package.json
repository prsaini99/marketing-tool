    "db:studio": "dotenv -e .env.local -- prisma studio",
    "cron-worker": "node scripts/cron-worker.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.46.1",
    "clsx": "^2.1.1",
