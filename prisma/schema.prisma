// Prisma schema — Phase 0.5 (Discovery only).
//
// Data flow:
//   Connection (pasted token, encrypted) →
//     MetaBusiness (discovered) →
//       MetaAdAccount (discovered, opt-in selectedForSync)
//
// Phase 1 adds Campaign / AdSet / Ad / InsightsSnapshot mirrored locally,
// driven by selectedForSync + a daily cron + 7-day re-pull.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App runtime uses the pooled connection (Supabase Transaction pooler / PgBouncer).
  url       = env("DATABASE_URL")
  // Migrations need a direct (non-pooled) connection because PgBouncer
  // doesn't support some operations Prisma uses for DDL.
  directUrl = env("DIRECT_URL")
}

// ─── Connections ─────────────────────────────────────────────────────────

enum ConnectionStatus {
  ACTIVE
  TOKEN_EXPIRING
  REVOKED
  ERROR
}

// One row per pasted Meta access token. A single connection can grant access
// to many businesses, so the relationship inverts vs. the old plan:
// MetaBusiness FKs to Connection here.
//
// Decrypt the token ONLY inside src/lib/meta/credentials.ts (PROJECT.md rule #5).
model Connection {
  id               String           @id @default(cuid())
  label            String?
  // Identity of the token's owner from Meta's /me endpoint. Unique across
  // connections — re-pasting any token for the same owner refreshes the
  // existing row instead of creating a duplicate.
  tokenOwnerFbId   String           @unique
  tokenOwnerName   String?
  encryptedToken   String
  iv               String
  authTag          String
  scopes           String[]
  expiresAt        DateTime?
  status           ConnectionStatus @default(ACTIVE)
  lastDiscoveredAt DateTime?

  businesses       MetaBusiness[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// ─── Discovered entities ─────────────────────────────────────────────────

// One row per Meta Business Manager discovered via a Connection.
// The same BM discovered by two different connections lives as two rows
// (one per connection) — uniqueness is per-connection.
model MetaBusiness {
  id              String   @id @default(cuid())
  metaBusinessId  String
  name            String
  connectionId    String
  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  selectedForSync Boolean  @default(false)

  adAccounts      MetaAdAccount[]
  embeddings      Embedding[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, metaBusinessId])
}

// Ad accounts under a MetaBusiness. selectedForSync gates whether Phase 1
// sync jobs will mirror campaigns/ad sets/ads/insights for this account.
//
// Account-health fields (balance/spendCap/...) are populated by the
// "account-detail" sync kind — these mirror what Meta's
// `/act_{id}?fields=...` returns. They drift on Meta's side as ads spend
// and top-ups clear, so the UI shows `healthSyncedAt` next to them so the
// reader knows how stale the number is. `null` everywhere means the detail
// sync hasn't run yet for this account.
model MetaAdAccount {
  id                  String   @id @default(cuid())
  metaAdAccountId     String   // e.g. "act_1234567890"
  name                String
  currency            String
  timezone            String
  status              String   // Meta's account status string
  selectedForSync     Boolean  @default(false)
  businessId          String
  business            MetaBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Account health fields — pulled from Meta on the "account-detail" sync.
  // Money in account-currency cents. `spendCapCents = null` means no cap.
  balanceCents        Int?
  spendCapCents       Int?
  amountSpentCents    Int?
  minDailyBudgetCents Int?
  fundingSourceId     String?
  businessCountryCode String?
  disableReason       String?  // null when account is healthy; stable code otherwise
  healthSyncedAt      DateTime?

  campaigns           Campaign[]
  adSets              AdSet[]
  ads                 Ad[]
  creatives           AdCreative[]
  images              AdImage[]
  videos              AdVideo[]
  audiences           CustomAudience[]
  conversions         CustomConversion[]
  insights            InsightsSnapshot[]
  syncLogs            SyncLog[]
  schedules           SyncSchedule[]
  embeddings          Embedding[]
  alerts              Alert[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([businessId, metaAdAccountId])
}

// Per-account, per-kind sync schedules configured from the UI.
// Tick endpoint scans this table for `enabled = true AND nextRunAt <= now`,
// runs the corresponding sync service, then computes the next run time.
//
// Granularity is intentional: senior wants explicit control over what runs
// and how often, to keep Meta API usage predictable.
model SyncSchedule {
  id          String   @id @default(cuid())
  adAccountId String
  adAccount   MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  kind        String   // "campaigns" | "adsets" | "ads" | "insights"
  frequency   String   // preset key — UI never deals with raw cron expressions
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([adAccountId, kind])
  @@index([enabled, nextRunAt])
}

// Mirrored campaigns. Pulled by Phase 1 sync jobs from Meta's
// /act_{id}/campaigns endpoint. One row per (adAccount, campaign) — re-syncs
// upsert by metaCampaignId so historical Campaign rows are stable across syncs.
model Campaign {
  id                  String   @id @default(cuid())
  metaCampaignId      String   // Meta's id
  adAccountId         String
  adAccount           MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  name                String
  status              String   // "ACTIVE" | "PAUSED" | "DELETED" | "ARCHIVED"
  objective           String?  // Meta's objective string; null if absent
  dailyBudgetCents    Int?
  lifetimeBudgetCents Int?
  // Campaign-wide lifetime spend ceiling (cents). null = no cap. Mirrored so
  // the Edit Campaign form can pre-fill it without a live fetch.
  spendCapCents       Int?
  metaUpdatedTime     DateTime? // Meta's last-edited timestamp for this campaign
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  adSets              AdSet[]

  @@unique([adAccountId, metaCampaignId])
}

// Ad sets under a Campaign. Pulled by Phase 1.1 sync from /act_{id}/adsets.
// Each ad set knows its parent campaign via campaign_id in the API response.
model AdSet {
  id                  String   @id @default(cuid())
  metaAdSetId         String
  adAccountId         String
  adAccount           MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  campaignId          String
  campaign            Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name                String
  status              String
  optimizationGoal    String?
  dailyBudgetCents    Int?
  lifetimeBudgetCents Int?
  metaUpdatedTime     DateTime?
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ads                 Ad[]

  @@unique([adAccountId, metaAdSetId])
}

// Ads under an AdSet. Phase 1.1 syncs basic metadata (creative `format` is
// extracted via a separate /{creative_id} call — deferred for now, left null).
//
// `metaCreativeId` + `creativeThumbnailUrl` link an ad to the creative it's
// using. Meta returns both inline via `?fields=creative{id,thumbnail_url}`,
// so we don't need a separate creative-detail fetch per ad. The
// metaCreativeId points to AdCreative.metaCreativeId for richer joins;
// thumbnail is mirrored on the Ad row so tables can render an inline
// preview without joining when AdCreative isn't synced yet.
model Ad {
  id                   String   @id @default(cuid())
  metaAdId             String
  adAccountId          String
  adAccount            MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adSetId              String
  adSet                AdSet @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  name                 String
  status               String   // Meta's `status` field — ACTIVE/PAUSED user intent
  // Meta's `effective_status` — the *real* delivery status after policy/billing
  // gates. Common values: ACTIVE, PAUSED, DISAPPROVED, WITH_ISSUES,
  // CAMPAIGN_PAUSED, ADSET_PAUSED, DELETED. Drives the policy alert.
  effectiveStatus      String?
  // Meta's `issues_info` array — populated when an ad has policy issues.
  // Each entry: { error_code, error_message, error_summary, level }.
  // Stored as JSON so we don't need a separate table for the few accounts
  // that ever have non-empty entries.
  issuesInfo           Json?
  format               String?  // "SINGLE_IMAGE" | "VIDEO" | "CAROUSEL" | "COLLECTION" | null
  metaCreativeId       String?
  creativeThumbnailUrl String?
  metaUpdatedTime      DateTime?
  syncedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([adAccountId, metaAdId])
}

// Ad creatives pulled from Meta's /act_{id}/adcreatives endpoint. A creative
// is the "design" half of an ad — body text, headline, image/video, link,
// CTA — owned at account level and reusable across multiple Ads. We mirror
// the most-displayed fields so the UI can render a browse grid without
// hitting Meta on every render. Long-form / structured fields (asset feed
// spec, full object_story_spec) are deliberately omitted — fetch them
// per-creative on detail view if needed later.
model AdCreative {
  id                  String   @id @default(cuid())
  metaCreativeId      String
  adAccountId         String
  adAccount           MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  // Meta sometimes leaves `name` blank (it's optional). We keep it nullable
  // and let the UI fall back to "Untitled creative" or the creative id.
  name                String?
  body                String?  // "primary text" in Ads Manager parlance
  title               String?  // headline
  linkUrl             String?
  imageUrl            String?
  imageHash           String?
  thumbnailUrl        String?
  videoId             String?
  callToActionType    String?  // SHOP_NOW, LEARN_MORE, SIGN_UP, …
  status              String?  // ACTIVE | IN_PROCESS | WITH_ISSUES | DELETED
  effectiveStoryId    String?  // page_id_post_id form; useful for previewing
  pageId              String?  // FB Page id from object_story_spec
  instagramActorId    String?
  objectType          String?  // SHARE | VIDEO | PHOTO | …
  syncedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([adAccountId, metaCreativeId])
}

// Raw images uploaded to an account's ad library — what `image_hash` on a
// creative actually points to. We mirror them so the UI can show a browse
// view AND a future Create-Ad picker can let users reuse an existing image
// instead of re-uploading. Meta's `hash` field is the natural id (it's
// content-addressed), so we make (adAccountId, hash) the unique key.
model AdImage {
  id              String   @id @default(cuid())
  metaImageHash   String   // Meta's `hash` — content-addressed image fingerprint
  adAccountId     String
  adAccount       MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  url             String?  // Direct CDN URL — short-lived; refetch if 404s
  name            String?  // Original filename if Meta retained it
  width           Int?
  height          Int?
  status          String?  // ACTIVE | DELETED | INTERNAL
  metaCreatedTime DateTime?
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([adAccountId, metaImageHash])
}

// Raw videos uploaded to an account's ad library. Same role as AdImage but
// for video assets — a creative references the underlying video by
// `video_id`, and one video can back many creatives. We mirror the metadata
// (not the file) so the UI can show a browse grid with thumbnails.
model AdVideo {
  id               String   @id @default(cuid())
  metaVideoId      String   // Meta's `id` for the video object
  adAccountId      String
  adAccount        MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  title            String?
  description      String?
  thumbnailUrl     String?  // Meta's `picture` field — single-frame poster
  sourceUrl        String?  // Direct mp4 URL — short-lived; refetch if 404s
  lengthSeconds    Float?
  status           String?  // ready | processing | error | …
  metaCreatedTime  DateTime?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([adAccountId, metaVideoId])
}

// Saved audience lists pulled from /act_X/customaudiences. A custom audience
// is a targeting shortcut — a pre-built list of specific people (uploaded
// CRM, pixel visitors, video viewers, lookalikes, …) that ad sets can
// include or exclude. Mirroring them lets the Create Ad Set picker present
// the agency's saved audiences as a dropdown instead of forcing the user to
// remember opaque Meta IDs.
//
// Money/count fields stay strings or ints depending on Meta's response —
// `approximateCount` is integer; Meta returns "1000+" for very small or
// privacy-bucketed audiences, in which case we store null.
model CustomAudience {
  id                 String   @id @default(cuid())
  metaAudienceId     String
  adAccountId        String
  adAccount          MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  name               String
  // CUSTOM | WEBSITE | LOOKALIKE | ENGAGEMENT | APP | OFFLINE_CONVERSION | …
  subtype            String?
  description        String?
  approximateCount   Int?
  // READY | PROCESSING | UPDATING | RECENTLY_USED | PENDING_TARGET …
  operationStatus    String?
  dataSourceSubtype  String?  // free-form Meta string, useful for UX hints
  metaCreatedTime    DateTime?
  syncedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([adAccountId, metaAudienceId])
}

// Saved custom conversions, pulled from /act_X/customconversions. A custom
// conversion is a rule layered on top of Pixel events ("Purchase with value
// > $100", "URL contains /thank-you", …) that ad sets reference via
// `promoted_object.custom_conversion_id` to optimize delivery + report ROI.
// We mirror them so the Create Ad Set form can present a picker beside the
// raw-Pixel-event entry path.
//
// `rule` is the JSON predicate string Meta returns verbatim — preserved
// (not parsed) so we can display it to the senior without round-tripping.
model CustomConversion {
  id                 String   @id @default(cuid())
  metaConversionId   String
  adAccountId        String
  adAccount          MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  // Raw JSON predicate (e.g. {"and":[{"event":{"eq":"Purchase"}},
  // {"value":{"gt":100}}]}). Stored as text since the shape is open-ended.
  rule               String?
  // PURCHASE | ADD_TO_CART | LEAD | COMPLETE_REGISTRATION | OTHER | …
  customEventType    String?
  // Pixel id this conversion is built on top of.
  eventSourceId      String?
  metaLastFiredTime  DateTime?
  metaCreatedTime    DateTime?
  syncedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([adAccountId, metaConversionId])
}

// Daily metric rows pulled from Meta's /act_X/insights endpoint at multiple
// levels (account, campaign, adset, ad). One row per (adAccount, date, level,
// entityId). Spend stored in account currency's smallest unit (cents).
// On re-sync, rows are upserted (Meta backfills attribution for ~28 days —
// Phase 1.3's cron re-pulls the last 7 days each night to catch updates).
model InsightsSnapshot {
  id          String   @id @default(cuid())
  adAccountId String
  adAccount   MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  level       String   // "account" | "campaign" | "adset" | "ad"
  entityId    String   // Meta id of the entity at this level
  impressions Int      @default(0)
  reach       Int      @default(0)
  clicks      Int      @default(0)
  spendCents  Int      @default(0)
  ctr         Float    @default(0) // 0..1
  cpmCents    Int      @default(0)
  // Conversion events (purchase + lead + registration + …) summed across
  // recognised action_types. ROAS is derived: revenueCents / spendCents.
  conversionsCount Int @default(0)
  revenueCents     Int @default(0)
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([adAccountId, date, level, entityId])
  @@index([adAccountId, date])
  @@index([level, entityId, date])
}

// ─── Operational ────────────────────────────────────────────────────────

// Records each sync attempt per ad account, per kind.
model SyncLog {
  id           String        @id @default(cuid())
  adAccountId  String
  adAccount    MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  kind         String        // "discovery" | "campaigns" | "ad_sets" | "ads" | "insights"
  status       String        // "success" | "failed"
  error        String?
  startedAt    DateTime
  finishedAt   DateTime?
}

// Every write operation we perform on Meta. Empty in Phase 0.5 (read-only),
// but the table exists so we never have to add it under pressure later.
// userId is nullable because we have no user-auth in Phase 0.5.
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // e.g. "connection.create", "ad_account.select"
  targetType  String
  targetId    String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())
}

// ─── Alerts ─────────────────────────────────────────────────────────────
//
// Daily anomaly digest — one row per account-per-day-where-something-shifted.
// The cron at /api/cron/alerts/daily walks selected-for-sync accounts, diffs
// yesterday vs the prior 7-day baseline, and (if anything's off) writes a
// row here with an LLM-narrated explanation. The Alerts page reads from
// here — same source whether the row came from cron or a manual "Run scan".
//
// `severity` lets the UI rank what matters; "info" rows are diagnostics the
// strategist can usually ignore. Dismissed alerts stay in the DB so the
// daily scan doesn't re-create them (unique constraint on account+date+key).
model Alert {
  id           String   @id @default(cuid())
  adAccountId  String
  adAccount    MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  forDate      DateTime @db.Date  // the day the anomaly refers to (usually yesterday)
  severity     String   // "high" | "medium" | "low" | "info"
  // Short slug describing what tripped — used both for de-dupe and for the
  // sidebar grouping later (e.g. "spend_drop", "delivery_stopped",
  // "adset_roas_drop", "ad_disapproved", "audience_overlap_high").
  kind         String
  // What the alert is ABOUT inside the account — lets ad-set, ad, and
  // audience-pair alerts coexist with account-level ones on the same day.
  // For account-level alerts, entityType="account" + entityId="".
  // For ad-set: entityType="adset" + entityId=Meta ad-set id.
  // For ad-pair audience overlap: entityType="audience_pair" + entityId="a|b".
  entityType   String   @default("account")
  entityId     String   @default("")
  entityName   String?  // cached display string (e.g. ad-set name)
  title        String   // headline, e.g. "Spend dropped 65% yesterday"
  body         String   // LLM-narrated explanation, plain-English
  metrics      Json     @default("{}") // structured numbers backing the alert
  dismissedAt  DateTime?
  createdAt    DateTime @default(now())

  // The unique tuple now includes entityId so multiple ad-sets / pairs can
  // have the same `kind` on the same day without colliding.
  @@unique([adAccountId, forDate, kind, entityId])
  @@index([dismissedAt])
  @@index([createdAt(sort: Desc)])
}

// ─── AI Assistant chat ──────────────────────────────────────────────────
//
// Persistent threads for the tool-using AI Assistant (/dashboard/chat).
// Single-user today, so no userId — when multi-user lands we'll add an
// owner. Threads are auto-titled from the first user message (truncated).
//
// Why persist: refresh-safe history + the ability to revisit past Q&A
// across sessions. Reconstruction into "turns" for the UI is done at read
// time — we store the raw OpenAI message shape (role/content/tool_calls
// /tool_call_id) so the chat loop can resume across turns.
model ChatThread {
  id        String        @id @default(cuid())
  title     String
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([updatedAt(sort: Desc)])
}

// One row per OpenAI chat message — covers user/assistant/tool. We keep
// the raw wire format (toolCalls JSON, toolCallId) so resuming the chat
// loop is a straight load + map, no reconstruction.
model ChatMessage {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role       String     // "user" | "assistant" | "tool"
  content    String     // "" when assistant only emitted tool_calls
  toolCalls  Json?      // assistant's tool_calls array (when present)
  toolCallId String?    // for tool messages — references the call id
  createdAt  DateTime   @default(now())

  @@index([threadId, createdAt])
}

// ─── RAG ────────────────────────────────────────────────────────────────
//
// Shared vector store for every RAG + LLM feature on the platform. One row =
// one chunk of text + its embedding. We never search the whole table — every
// query is scoped to a namespace (e.g. "ads", "brand_docs", "audit_findings")
// AND to a businessId or adAccountId so a client never sees another's data.
//
// `vector` is `Unsupported("vector(1536)")` because Prisma has no native
// pgvector type yet — read/write it via $queryRaw / $executeRaw (see
// src/server/services/rag/). Everything else is plain Prisma.
//
// Re-indexing the same source overwrites: the (namespace, sourceType,
// sourceId) tuple is unique, so an upsert handles updates idempotently.
//
// Embedding model used at index time is recorded in `metadata.model` so we
// can detect when a row needs re-embedding after a model swap.
model Embedding {
  id           String   @id @default(cuid())
  namespace    String   // partition: "ads" | "brand_docs" | "audit_findings" | ...
  sourceType   String   // origin table: "Ad" | "AdCreative" | "BrandDoc" | ...
  sourceId     String   // origin row id (or any stable string for non-DB sources)
  content      String   // raw text that was embedded — returned with hits
  vector       Unsupported("vector(1536)")
  // Tenant scoping. At least one MUST be set for any tenant-specific corpus —
  // search always filters by one of these so cross-tenant leakage is impossible.
  businessId   String?
  business     MetaBusiness? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  adAccountId  String?
  adAccount    MetaAdAccount? @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([namespace, sourceType, sourceId])
  @@index([businessId, namespace])
  @@index([adAccountId, namespace])
}
